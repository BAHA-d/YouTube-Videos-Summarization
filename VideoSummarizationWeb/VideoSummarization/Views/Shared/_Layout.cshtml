@using System.Security.Claims
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Video Summarization</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <meta content="" name="description">
    <meta content="" name="keywords">

    <!-- Favicons -->
    <link href="~/img/logo.png" rel="icon">
    <link href="assets/img/apple-touch-icon.png" rel="apple-touch-icon">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Raleway:300,300i,400,400i,500,500i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i" rel="stylesheet">

    <!-- Vendor CSS Files -->
    <link href="~/vendor/aos/aos.css" rel="stylesheet">
    <link href="~/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="~/vendor/boxicons/css/boxicons.min.css" rel="stylesheet">
    <link href="~/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="~/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <!-- Template Main CSS File -->
    <link href="~/css/style.css" rel="stylesheet">
    <!-- Template Main CSS File -->
    <link href="~/css/style.css" rel="stylesheet">
</head>

<body>
    <!-- ======= Top Bar ======= -->
  <section id="topbar" class="d-flex align-items-center">
    <div class="container d-flex justify-content-center justify-content-md-between">
      <div class="contact-info d-flex align-items-center">
        <i class="bi bi-envelope d-flex align-items-center"><a href="info@VideoSummarize.com">info@VideoSummarize.com</a></i>
        <i class="bi bi-phone d-flex align-items-center ms-4"><span>+962 79 555 5555</span></i>
      </div>
      <div class="social-links d-none d-md-flex align-items-center">
        <a href="usecontrol.html" class="icon" style="display: none;"><i class="fa-solid fa-gear"></i> Control Panel</a>
        
                @if (User.Identity.IsAuthenticated)
                {
                    <a asp-controller="Accounts" asp-action="Logout">Sign out</a>
                }else{
                    <a asp-controller="Accounts" asp-action="Register">Sign Up</a>
                    <a asp-controller="Accounts" asp-action="Login">Sign In</a>
                }

        <!-- <a href="#" class="twitter"><i class="bi bi-twitter"></i></a>
        <a href="#" class="facebook"><i class="bi bi-facebook"></i></a>
        <a href="#" class="instagram"><i class="bi bi-instagram"></i></a>
        <a href="#" class="linkedin"><i class="bi bi-linkedin"></i></i></a> -->
      </div>
    </div>
  </section>

    <header id="header" class="d-flex align-items-center">
        <div class="container d-flex justify-content-between">
            <div class="logo">
                <a href="@Url.Action("Index","Home")"><img src="~/img/logo.png" alt="" class="img-fluid"></a>
            </div>

            <nav id="navbar" class="navbar">
                @if(User.Identity.IsAuthenticated)
                {
                    if(User.FindFirst(ClaimTypes.Role)?.Value == "Admin")
                    {
                        <ul>
                            <li><a class="nav-link scrollto active" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a class="nav-link scrollto" asp-controller="VideoSummarize" asp-action="Index">Video summurize</a></li>
                            <li><a class="nav-link scrollto" asp-controller="Users" asp-action="Index">Manage Users</a></li>
                        </ul>
                        <i class="bi bi-list mobile-nav-toggle"></i>
                    }else{
                        <ul>
                            <li><a class="nav-link scrollto active" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a class="nav-link scrollto" asp-controller="Home" asp-action="AboutUs">About Us</a></li>
                            <li><a class="nav-link scrollto" asp-controller="VideoSummarize" asp-action="Index">Video summurize</a></li>
                            <li><a class="nav-link scrollto" asp-controller="Home" asp-action="ContactUs">Contact Us</a></li>
                        </ul>
                        <i class="bi bi-list mobile-nav-toggle"></i>
                    }
                }
                else
                {
                    <ul>
                        <li><a class="nav-link scrollto active" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a class="nav-link scrollto" asp-controller="Home" asp-action="AboutUs">About Us</a></li>
                        <li><a class="nav-link scrollto" asp-controller="VideoSummarize" asp-action="Index">Video summarize</a></li>
                        <li><a class="nav-link scrollto" asp-controller="Home" asp-action="ContactUs">Contact Us</a></li>
                    </ul>
                    <i class="bi bi-list mobile-nav-toggle"></i>
                }

                
            </nav><!-- .navbar -->

        </div>
    </header>

    <div>
        <main role="main" id="main">
            @RenderBody()
        </main>
    </div>

    <!-- ======= Footer ======= -->
    <footer id="footer">

        <div class="footer-top">

            <div class="container">

                <div class="row justify-content-center">
                    <div class="col-lg-3">
                        <span> <a asp-controller="Home" asp-action="Index"><img src="~/img/footer-logo.png" alt="" class="img-fluid"></a></span>
                    </div>
                </div>


            </div>
        </div>

        <div class="container footer-bottom clearfix">
            <div class="copyright">
                &copy; Copyright <strong><span>Video Summarization</span></strong>. All Rights Reserved
            </div>
        </div>
    </footer><!-- End Footer -->

    <a href="#" class="back-to-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Vendor JS Files -->
    <script src="~/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="~/vendor/aos/aos.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="~/vendor/isotope-layout/isotope.pkgd.min.js"></script>
    <script src="~/vendor/swiper/swiper-bundle.min.js"></script>
    <script src="~/vendor/php-email-form/validate.js"></script>

    <!-- Template Main JS File -->
    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
