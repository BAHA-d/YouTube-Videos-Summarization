<section class="vh-80 gradient-custom" style="background-color: #eaedf1;">
    <div class="container py-5 h-100">
        <div class="row justify-content-center align-items-center h-100">
            <div class="col-12 col-lg-12 col-xl-12">
                <div class="card shadow-2-strong card-registration" style="border-radius: 15px;">
                    <div class="card-body p-4 p-md-5">
                        <h3 class="mb-4 pb-2 pb-md-0 mb-md-5">Summerize Video</h3>
                        <form asp-controller="VideoSummarize" asp-action="Index" method="post">

                            <div class="row">
                                <div class="col-md-12 mb-4">

                                    <div class="form-outline">
                                        <label class="form-label" for="Url"> Video URL </label>
                                        <input type="text" id="Url" name="url" class="form-control form-control-lg" value="@ViewBag.url" />
                                    </div>

                                </div>
                            </div>

                            <div class="row justify-content-center">
                                <div class="col-lg-7 col-md-10 col-sm-12 text-center">
                                    <iframe width="100%" height="315" id="iFrame" style="display: none;" src="" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                                    <p id="errorMessage" style="color: red; display: none;">Invalid YouTube URL</p>
                                </div>
                            </div>

                            <div class="text-center mt-2 pt-2">
                                <input class="btn btnrrsv btn-lg" type="submit" value="Summarize" disabled id="summarizeBtn"/>
                            </div>

                            <div class="row">
                                <div class="col-lg-6 col-md-12 my-4">
                                    <div class="form-outline datepicker w-100 col-md-6 ml-5 text-center">
                                        <label for="Summury" class="form-label"> Transcript </label>
                                        <textarea class="form-control form-control-lg" id="Transcript" disabled rows="10">@ViewBag.script</textarea>
                                    </div>
                                </div>
                                <div class="col-lg-6 col-md-12 my-4">
                                    <div class="form-outline datepicker w-100 col-md-6 ml-5 text-center">
                                        <label for="Summury" class="form-label"> Video Summary </label>
                                        <textarea class="form-control form-control-lg" id="Summury" disabled rows="10">@ViewBag.summ</textarea>
                                    </div>
                                </div>
                            </div>
                            
                        </form>

                        <div class="text-center mt-2 pt-2">
                            <input class="btn btnrrsv btn-lg" type="submit" value="    Download Summary    " id="DownloadSummary" hidden />
                           
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>


    function getYoutubeVideoId(url) {
        const regExp = /(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([\w-]{11})/;
        const match = url.match(regExp);
        return match ? match[1] : null;
    }

    document.getElementById('Url').addEventListener('input', function () {
        var url = this.value;
        if (isValidYoutubeUrl(url)) {
            var videoId = getYoutubeVideoId(url);
            if(videoId){
                document.getElementById('iFrame').src = "https://www.youtube.com/embed/" + videoId;
                document.getElementById('iFrame').style.display = 'block';
                document.getElementById('errorMessage').style.display = 'none';
                document.getElementById('DownloadSummary').hidden = false;
                document.getElementById('summarizeBtn').disabled = false;
            }
            else
            {
                document.getElementById('iFrame').style.display = 'none';
                document.getElementById('errorMessage').style.display = 'block';
                document.getElementById('summarizeBtn').disabled = true;
            }
         
        }
        else if (url == "")
        {
            document.getElementById('iFrame').style.display = 'none';
            document.getElementById('errorMessage').style.display = 'none';
            document.getElementById('summarizeBtn').disabled = true;
        }
        else
        {
            document.getElementById('iFrame').style.display = 'none';
            document.getElementById('errorMessage').style.display = 'block';
            document.getElementById('summarizeBtn').disabled = true;
        }

    });

    document.addEventListener("DOMContentLoaded", function () {
        var summ = document.getElementById('Summury').value;
        if (summ != null) {
           
            document.getElementById('DownloadSummary').hidden = false;
        }
        else {
           
            document.getElementById('DownloadSummary').hidden = true;
        }
    });

    document.getElementById('DownloadSummary').addEventListener('click', function () {
        var summ = document.getElementById('Summury').value;

        var fileName = "summary.txt";

        downloadTextFile(summ, fileName);
    });
    
    function downloadTextFile(text, filename) {

        const blob = new Blob([text], { type: 'text/plain' });

        const link = document.createElement('a');

        link.href = window.URL.createObjectURL(blob);
        link.download = filename;

        document.body.appendChild(link);

        link.click();

        document.body.removeChild(link);
        window.URL.revokeObjectURL(link.href);
    }

    function getParameterByName(name, url) {
        if (!url) url = window.location.href;
        name = name.replace(/[\[\]]/g, '\\$&');
        var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'),
            results = regex.exec(url);
        if (!results) return null;
        if (!results[2]) return '';
        return decodeURIComponent(results[2].replace(/\+/g, ' '));
    }

       function isValidYoutubeUrl(url) {
        var pattern = /^(https?:\/\/)?(www\.)?(youtube\.com\/(watch\?v=|shorts\/)|youtu\.be\/)[\w-]{11}/;
        return pattern.test(url);
    }
</script>